source ~/.config/fish/functions/hyprconf.fish
source ~/.config/fish/functions/waybarconf.fish
source ~/.config/fish/functions/waybarconfjs.fish
set -x fish_greeting ""
if status is-interactive
    echo ' /$$   /$$  /$$$$$$  /$$$$$$$$ /$$      /$$ /$$$$$$$$'
    echo '| $$$ | $$ /$$__  $$|__  $$__/| $$$    /$$$| $$_____/'
    echo '| $$$$| $$| $$  \ $$   | $$   | $$$$  /$$$$| $$      '
    echo '| $$ $$ $$| $$  | $$   | $$   | $$ $$/$$ $$| $$$$$   '
    echo '| $$  $$$$| $$  | $$   | $$   | $$  $$$| $$| $$__/   '
    echo '| $$\  $$$| $$  | $$   | $$   | $$\  $ | $$| $$'
    echo '| $$ \  $$|  $$$$$$/   | $$   | $$ \/  | $$| $$$$$$$$'
    echo '|__/  \__/ \______/    |__/   |__/     |__/|________/'
    fastfetch --logo none --logo-padding-left 0 --logo-padding-top 0
    # Commands to run in interactive sessions can go here
set -g theme_display_glyphs yes
set -g theme_nerd_fonts yes
set -g theme_color_scheme dark
source ~/.local/share/omf/init.fish
source ~/.local/share/omf/init.fish
source ~/.local/share/omf/init.fish
	end
